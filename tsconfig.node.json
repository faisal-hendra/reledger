{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/db/**/*.ts"],
  "compilerOptions": {
    "module": "es2020",
    "composite": true,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@": ["./src/renderer/src/*"],
      "@renderer": ["./src/renderer/src/*"]
    },
    "moduleResolution": "bundler",
    "lib": [
      "es5", "es6", "dom", "dom.iterable"
    ]
  },
    "include": ["src/**/*", "src/types/global.d.ts"]
}
